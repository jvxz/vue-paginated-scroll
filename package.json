{
  "name": "@jamii/vue-paginated-scroll",
  "version": "1.0.2",
  "description": "Headless Vue composable for stable, bidirectional paginated scrolling",
  "keywords": [
    "chat",
    "composable",
    "headless",
    "infinite-scroll",
    "pagination",
    "scroll",
    "timeline",
    "vue"
  ],
  "license": "MIT",
  "author": "Jamie",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
    "dev": "vite build --watch",
    "dev:playground": "vite --config playground/vite.config.ts",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepublishOnly": "pnpm build",
    "release": "bumpp && changelogen --release --push && npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.1",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "bumpp": "^11.1.0",
    "changelogen": "^0.6.2",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.6"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
